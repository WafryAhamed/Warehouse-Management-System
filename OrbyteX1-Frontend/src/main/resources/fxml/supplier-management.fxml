<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.orbytex.orbytex1.controller.SupplierManagementController"
            style="-fx-background-color: #F5F6F8;">

    <!-- Top Bar -->
    <top>
        <HBox spacing="20" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">
            <HBox.hgrow><Priority priority="ALWAYS"/></HBox.hgrow>
            <Label text="🏭 Supplier Management" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #FF4D1A;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userNameLabel" text="User" style="-fx-font-size: 12; -fx-text-fill: #6B7280;"/>
            <Button text="Logout" onAction="#handleLogout" style="-fx-padding: 8 15; -fx-font-size: 12;"/>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <HBox spacing="10">
                <TextField promptText="Search suppliers..." style="-fx-padding: 8; -fx-font-size: 12; -fx-border-radius: 6;"/>
                <Button fx:id="addSupplierButton" text="Add Supplier" onAction="#handleAddSupplier"
                        style="-fx-padding: 10 20; -fx-font-size: 12; -fx-text-fill: white; -fx-background-color: #FF4D1A;"/>
                <Button fx:id="editSupplierButton" text="Edit" onAction="#handleEditSupplier"
                        style="-fx-padding: 10 20; -fx-font-size: 12;"/>
            </HBox>

            <TableView fx:id="suppliersTable" style="-fx-background-color: white; -fx-padding: 10;">
                <columns>
                    <TableColumn text="Supplier Name" prefWidth="150"/>
                    <TableColumn text="Contact Person" prefWidth="150"/>
                    <TableColumn text="Email" prefWidth="150"/>
                    <TableColumn text="Phone" prefWidth="120"/>
                    <TableColumn text="Payment Terms" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>

