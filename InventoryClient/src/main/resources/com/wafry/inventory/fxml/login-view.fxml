<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>

<!--
  ENTERPRISE Inventory Management System
  Login Page - Professional Authentication UI
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.wafry.inventory.controller.LoginController"
            style="-fx-font-family: 'Segoe UI'; -fx-font-size: 12;">

    <!-- CENTER: Login Form -->
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-background-color: #ecf0f1;">

            <!-- Main Login Container -->
            <VBox alignment="TOP_CENTER" spacing="15" style="-fx-background-color: white;
                                                             -fx-padding: 40;
                                                             -fx-border-color: #bdc3c7;
                                                             -fx-border-width: 1;
                                                             -fx-border-radius: 5;
                                                             -fx-max-width: 350;"
                   VBox.vgrow="NEVER">

                <!-- Header -->
                <Label text="INVENTORY MANAGEMENT SYSTEM"
                       style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Label text="Enterprise Edition"
                       style="-fx-font-size: 11; -fx-text-fill: #7f8c8d; -fx-padding: 0 0 10 0;"/>

                <!-- Divider -->
                <Label style="-fx-border-color: #ecf0f1; -fx-border-width: 1 0 0 0; -fx-padding: 5 0 10 0;"/>

                <!-- Username Field -->
                <Label text="Username"
                       style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <TextField fx:id="usernameField"
                          promptText="Enter username"
                          style="-fx-font-size: 11; -fx-padding: 8; -fx-border-color: #bdc3c7;"/>

                <!-- Password Field -->
                <Label text="Password"
                       style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-padding: 10 0 0 0;"/>
                <PasswordField fx:id="passwordField"
                              promptText="Enter password"
                              style="-fx-font-size: 11; -fx-padding: 8; -fx-border-color: #bdc3c7;"/>

                <!-- Error Message -->
                <Label fx:id="errorLabel"
                       text=""
                       style="-fx-text-fill: #e74c3c; -fx-font-size: 10; -fx-padding: 5 0 0 0;"/>

                <!-- Login Button -->
                <Button fx:id="loginButton"
                       text="Login"
                       onAction="#onLoginButtonClick"
                       style="-fx-font-size: 12;
                               -fx-padding: 10;
                               -fx-text-fill: white;
                               -fx-background-color: #27ae60;
                               -fx-border-radius: 3;
                               -fx-padding: 10;"
                       HBox.hgrow="ALWAYS"
                       maxWidth="Infinity"/>

                <!-- Demo Info -->
                <Label text="Demo: username/password"
                       style="-fx-font-size: 10; -fx-text-fill: #95a5a6; -fx-padding: 10 0 0 0;"/>

            </VBox>

            <HBox HBox.hgrow="ALWAYS"/>
        </VBox>
    </center>

</BorderPane>

