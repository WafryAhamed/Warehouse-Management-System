<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color: #F5F6F8;">
    <top>
        <HBox spacing="20" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">
            <Label text="📊 Products" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #FF4D1A;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" style="-fx-padding: 8 15; -fx-font-size: 12;"/>
        </HBox>
    </top>
    <center>
        <Label text="Products Page - Coming Soon" style="-fx-font-size: 18; -fx-text-fill: #6B7280;" alignment="CENTER"/>
    </center>
</BorderPane>

