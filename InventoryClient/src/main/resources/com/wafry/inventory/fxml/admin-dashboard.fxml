<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.wafry.inventory.controller.AdminDashboardController"
            style="-fx-background-color: #F5F6F8;">

    <!-- Top Bar -->
    <top>
        <HBox spacing="20" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">
            <HBox.hgrow><Priority priority="ALWAYS"/></HBox.hgrow>

            <Label text="OrbyteX1" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #FF4D1A;"/>
            <Separator orientation="VERTICAL"/>

            <VBox spacing="2">
                <Label fx:id="userFullNameLabel" text="Admin User" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <Label fx:id="userRoleLabel" text="ADMIN" style="-fx-font-size: 11; -fx-text-fill: #6B7280;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-padding: 8 15; -fx-font-size: 12; -fx-text-fill: white; -fx-background-color: #FF4D1A; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <ScrollPane style="-fx-padding: 20;">
            <VBox spacing="20">
                <Insets top="20" right="20" bottom="20" left="20"/>

                <!-- Header -->
                <VBox spacing="5">
                    <Label text="Dashboard" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                    <Label text="Welcome to OrbyteX1 Admin Dashboard" style="-fx-font-size: 14; -fx-text-fill: #6B7280;"/>
                </VBox>

                <!-- Loading Indicator -->
                <ProgressIndicator fx:id="loadingIndicator" visible="true" style="-fx-padding: 20;"/>

                <!-- KPI Cards -->
                <GridPane hgap="20" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>

                    <!-- Total Revenue Card -->
                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 16; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0.0, 0, 2);">
                        <Label text="Total Revenue" style="-fx-font-size: 12; -fx-text-fill: #6B7280;"/>
                        <Label fx:id="totalRevenueLabel" text="₹0.00" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #FF4D1A;"/>
                        <Label text="Current Month" style="-fx-font-size: 11; -fx-text-fill: #6B7280;"/>
                        <GridPane.setColumnIndex><Integer>0</Integer></GridPane.setColumnIndex>
                        <GridPane.setRowIndex><Integer>0</Integer></GridPane.setRowIndex>
                    </VBox>

                    <!-- Total Orders Card -->
                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 16; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0.0, 0, 2);">
                        <Label text="Total Orders" style="-fx-font-size: 12; -fx-text-fill: #6B7280;"/>
                        <Label fx:id="totalOrdersLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #FF4D1A;"/>
                        <Label text="Completed Orders" style="-fx-font-size: 11; -fx-text-fill: #6B7280;"/>
                        <GridPane.setColumnIndex><Integer>1</Integer></GridPane.setColumnIndex>
                        <GridPane.setRowIndex><Integer>0</Integer></GridPane.setRowIndex>
                    </VBox>

                    <!-- Total Customers Card -->
                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 16; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0.0, 0, 2);">
                        <Label text="Total Customers" style="-fx-font-size: 12; -fx-text-fill: #6B7280;"/>
                        <Label fx:id="totalCustomersLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #FF4D1A;"/>
                        <Label text="Active Customers" style="-fx-font-size: 11; -fx-text-fill: #6B7280;"/>
                        <GridPane.setColumnIndex><Integer>2</Integer></GridPane.setColumnIndex>
                        <GridPane.setRowIndex><Integer>0</Integer></GridPane.setRowIndex>
                    </VBox>

                    <!-- Total Products Card -->
                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 16; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0.0, 0, 2);">
                        <Label text="Total Products" style="-fx-font-size: 12; -fx-text-fill: #6B7280;"/>
                        <Label fx:id="totalProductsLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #FF4D1A;"/>
                        <Label text="Active Products" style="-fx-font-size: 11; -fx-text-fill: #6B7280;"/>
                        <GridPane.setColumnIndex><Integer>3</Integer></GridPane.setColumnIndex>
                        <GridPane.setRowIndex><Integer>0</Integer></GridPane.setRowIndex>
                    </VBox>

                    <!-- Low Stock Alert Card -->
                    <VBox spacing="10" style="-fx-background-color: #FFF1E6; -fx-padding: 20; -fx-border-radius: 16; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0.0, 0, 2);">
                        <Label text="Low Stock Alert" style="-fx-font-size: 12; -fx-text-fill: #FF4D1A;"/>
                        <Label fx:id="lowStockLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #FF4D1A;"/>
                        <Label text="Products to Reorder" style="-fx-font-size: 11; -fx-text-fill: #FF4D1A;"/>
                        <GridPane.setColumnIndex><Integer>0</Integer></GridPane.setColumnIndex>
                        <GridPane.setRowIndex><Integer>1</Integer></GridPane.setRowIndex>
                    </VBox>

                    <!-- Net Profit Card -->
                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 16; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0.0, 0, 2);">
                        <Label text="Net Profit" style="-fx-font-size: 12; -fx-text-fill: #6B7280;"/>
                        <Label fx:id="netProfitLabel" text="₹0.00" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #FF4D1A;"/>
                        <Label text="This Month" style="-fx-font-size: 11; -fx-text-fill: #6B7280;"/>
                        <GridPane.setColumnIndex><Integer>1</Integer></GridPane.setColumnIndex>
                        <GridPane.setRowIndex><Integer>1</Integer></GridPane.setRowIndex>
                    </VBox>

                    <!-- Active Users Card -->
                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 16; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0.0, 0, 2);">
                        <Label text="Active Users" style="-fx-font-size: 12; -fx-text-fill: #6B7280;"/>
                        <Label fx:id="activeUsersLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #FF4D1A;"/>
                        <Label text="System Users" style="-fx-font-size: 11; -fx-text-fill: #6B7280;"/>
                        <GridPane.setColumnIndex><Integer>2</Integer></GridPane.setColumnIndex>
                        <GridPane.setRowIndex><Integer>1</Integer></GridPane.setRowIndex>
                    </VBox>
                </GridPane>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

